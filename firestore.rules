rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function hasOnlyKeys(data, allowedKeys) {
      return data.keys().hasOnly(allowedKeys);
    }

    function validUser() {
      return hasOnlyKeys(request.resource.data, [
        'uid',
        'email',
        'displayName',
        'photoURL',
        'provider',
        'theme',
        'createdAt',
        'updatedAt'
      ]) &&
      request.resource.data.uid == request.auth.uid &&
      request.resource.data.email is string &&
      request.resource.data.displayName is string &&
      request.resource.data.provider is string;
    }

    function validCategory() {
      return hasOnlyKeys(request.resource.data, [
        'uid',
        'type',
        'name',
        'isDefault',
        'createdAt',
        'updatedAt'
      ]) &&
      request.resource.data.uid == request.auth.uid &&
      request.resource.data.type in ['รายรับ', 'รายจ่าย'] &&
      request.resource.data.name is string &&
      request.resource.data.name.size() > 0;
    }

    function validTransaction() {
      return hasOnlyKeys(request.resource.data, [
        'uid',
        'date',
        'type',
        'category',
        'description',
        'amount',
        'createdAt',
        'updatedAt'
      ]) &&
      request.resource.data.uid == request.auth.uid &&
      request.resource.data.type in ['รายรับ', 'รายจ่าย'] &&
      request.resource.data.category is string &&
      request.resource.data.category.size() > 0 &&
      request.resource.data.description is string &&
      request.resource.data.description.size() > 0 &&
      request.resource.data.amount is number &&
      request.resource.data.amount > 0 &&
      request.resource.data.date is string &&
      request.resource.data.date.matches('^\\d{4}-\\d{2}-\\d{2}$');
    }

    match /users/{userId} {
      allow create: if isOwner(userId) && validUser();
      allow read, delete: if isOwner(userId);
      allow update: if isOwner(userId) && validUser();
    }

    match /categories/{categoryId} {
      allow create: if isSignedIn() && validCategory();
      allow read, delete: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow update: if isSignedIn() &&
        resource.data.uid == request.auth.uid &&
        request.resource.data.uid == request.auth.uid &&
        validCategory();
    }

    match /transactions/{transactionId} {
      allow create: if isSignedIn() && validTransaction();
      allow read, delete: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow update: if isSignedIn() &&
        resource.data.uid == request.auth.uid &&
        request.resource.data.uid == request.auth.uid &&
        validTransaction();
    }
  }
}
